#include <iostream>
using namespace std;

int main() {
    char str[100001];
    cin >> str;

    int flag = 0;
    int flag1 = 0;

    for (int i = 0; str[i]; i++) {

        if (str[i] >= 'a' && str[i] <= 'z') {
            flag = flag | (1 << (str[i] - 'a'));
        }

        if (str[i] >= 'A' && str[i] <= 'Z') {
            flag1 = flag1 | (1 << (str[i] - 'A'));
        }
    }

    if ((flag == (1 << 26) - 1) && (flag1 == (1 << 26) - 1)) {
        cout << "yes";
    } else {
        cout << "no";
    }

    return 0;
}
