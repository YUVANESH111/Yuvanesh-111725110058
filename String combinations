#include <iostream>
using namespace std;

int main() {
    string str;
    cin >> str;

    int n = str.length();

    for(int i = 1; i < (1 << n); i++) {
        string ans = "";

        for(int j = 0; j < n; j++) {
            if(i & (1 << j)) {
                ans += str[j];
            }
        }

        cout << ans << endl;
    }

    return 0;
}
